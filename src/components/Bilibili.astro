---
// src/components/Bilibili.astro
export interface Props {
  bvid: string;  // 接收BV号作为参数
  title?: string;
}
const { bvid, title = 'Bilibili 视频' } = Astro.props;
const playerSrc = `https://player.bilibili.com/player.html?bvid=${bvid}&page=1`;
---

<div class="bilibili-embed">
  <iframe
    src={playerSrc}
    title={title}
    scrolling="no"
    border="0"
    frameborder="no"
    framespacing="0"
    allowfullscreen="true"
    sandbox="allow-same-origin allow-scripts allow-popups allow-forms allow-presentation"
  ></iframe>
</div>

<style>
  .bilibili-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
  }
  .bilibili-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>