---
import Layout from '../layouts/Layout.astro';
import config from '../data/config.json';

const projectsData = (await Astro.glob('../data/projects/*.json')).map(p => p.default);

let allPosts = [];
try {
  const temp = await Astro.glob('../data/articles/*.{md,mdx}');
  allPosts = Array.isArray(temp) ? temp : [];
} catch {
  allPosts = [];
}

if (allPosts.length > 0) {
  allPosts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
}
const recentPosts = allPosts.slice(0, 2);

const formatDate = (d: string) => new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const featuredProjects = projectsData.filter(p => p.featured);

const getSlug = (file: string) => file.split(/[/\\]/).pop()?.replace(/\.(md|mdx)$/, '') || '';
---
<Layout title={config.site.title} description={config.site.description}>
  <div class="min-h-screen">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary/10 via-surface to-secondary/10 py-20">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center animate-slide-up">
          <h1 class="text-5xl md:text-6xl font-bold mb-6">
            {config.site.subtitle}
          </h1>
          <p class="text-xl text-text-muted mb-8 max-w-2xl mx-auto">
            {config.site.description}
          </p>
          <div class="flex justify-center gap-4">
            <a href="/blog/" class="px-8 py-3 bg-primary text-white rounded-lg hover:bg-primary/90 transition font-medium">
              浏览博客
            </a>
            <a href="/projects/" class="px-8 py-3 border-2 border-border rounded-lg hover:border-primary transition font-medium">
              查看项目
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Recent Posts -->
    <section class="max-w-6xl mx-auto px-4 py-16">
      <h2 class="text-3xl font-bold mb-8">最新文章</h2>
      {recentPosts.length === 0 ? (
        <div class="text-center py-12 bg-surface-alt rounded-xl">
          <p class="text-text-muted">暂无文章，敬请期待...</p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 gap-6">
          {recentPosts.map((post, i) => {
            const slug = getSlug(post.file);
            return (
              <a href={`/blog/${slug}/`} class="block p-6 bg-surface-alt rounded-xl border border-border hover:shadow-lg transition animate-fade-in" style={`animation-delay: ${i * 0.1}s`}>
                <div class="flex gap-2 mb-3">
                  {post.frontmatter.tags?.map((tag: string) => (
                    <span class="text-xs px-2 py-1 bg-primary/10 text-primary rounded">{tag}</span>
                  ))}
                </div>
                <h3 class="text-xl font-semibold mb-2">{post.frontmatter.title}</h3>
                <p class="text-text-muted mb-3">{post.frontmatter.description || ''}</p>
                <time class="text-sm text-text-muted">{formatDate(post.frontmatter.date)}</time>
              </a>
            );
          })}
        </div>
      )}
    </section>

    <!-- Featured Projects -->
    <section class="bg-surface-alt py-16">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-3xl font-bold mb-8">精选项目</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {featuredProjects.map((project, i) => (
            <div class="bg-surface rounded-xl border border-border hover:shadow-lg transition animate-slide-up overflow-hidden" style={`animation-delay: ${i * 0.1}s`}>
              {project.images?.length > 0 ? (
                <div class="project-carousel relative aspect-video bg-surface-alt" data-carousel-id={`carousel-${i}`}>
                  {project.images.map((img: string, j: number) => (
                    <img src={img} alt={`${project.title} ${j + 1}`} class={`carousel-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ${j === 0 ? 'opacity-100' : 'opacity-0'}`} data-index={j} />
                  ))}
                  {project.images.length > 1 && (
                    <>
                      <button class="carousel-prev absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 bg-black/40 text-white rounded-full flex items-center justify-center hover:bg-black/60 transition z-10" data-action="prev"><i class="fas fa-chevron-left text-xs"></i></button>
                      <button class="carousel-next absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 bg-black/40 text-white rounded-full flex items-center justify-center hover:bg-black/60 transition z-10" data-action="next"><i class="fas fa-chevron-right text-xs"></i></button>
                      <div class="carousel-dots absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
                        {project.images.map((_: string, j: number) => (
                          <span class={`carousel-dot w-2 h-2 rounded-full transition-colors ${j === 0 ? 'bg-white' : 'bg-white/40'}`} data-dot={j}></span>
                        ))}
                      </div>
                    </>
                  )}
                </div>
              ) : (
                <div class="aspect-video bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center">
                  <i class="fas fa-code text-5xl text-primary/40"></i>
                </div>
              )}
              <a href={`/projects/${project.slug}/`} class="block p-6">
                <h3 class="text-xl font-semibold mb-2">{project.title}</h3>
                <p class="text-text-muted mb-3">{project.description}</p>
                <div class="flex gap-2">
                  {project.tags.map((tag: string) => (
                    <span class="text-xs px-2 py-1 bg-secondary/10 text-secondary rounded">{tag}</span>
                  ))}
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  document.querySelectorAll('.project-carousel').forEach(carousel => {
    const slides = carousel.querySelectorAll('.carousel-slide');
    const dots = carousel.querySelectorAll('.carousel-dot');
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      slides.forEach((s, i) => {
        (s as HTMLElement).classList.toggle('opacity-100', i === index);
        (s as HTMLElement).classList.toggle('opacity-0', i !== index);
      });
      dots.forEach((d, i) => {
        d.classList.toggle('bg-white', i === index);
        d.classList.toggle('bg-white/40', i !== index);
      });
      current = index;
    }

    carousel.querySelector('[data-action="prev"]')?.addEventListener('click', (e) => {
      e.preventDefault();
      goTo((current - 1 + slides.length) % slides.length);
      resetTimer();
    });
    carousel.querySelector('[data-action="next"]')?.addEventListener('click', (e) => {
      e.preventDefault();
      goTo((current + 1) % slides.length);
      resetTimer();
    });
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        goTo(Number((dot as HTMLElement).dataset.dot));
        resetTimer();
      });
    });

    function resetTimer() { clearInterval(timer); timer = setInterval(() => goTo((current + 1) % slides.length), 4000); }
    if (slides.length > 1) timer = setInterval(() => goTo((current + 1) % slides.length), 4000);
  });
</script>
